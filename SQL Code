CREATE DATABASE TechLayoffsProject;

USE TechLayoffsProject;

SELECT TOP 10 *
FROM layoffs;

EXEC sp_help layoffs;

------------DATA CLEANING--------------
-------Converting the 'Date_layoffs' column to proper date
UPDATE layoffs
SET Date_layoffs = TRY_CONVERT(DATE, Date_layoffs, 101);

ALTER TABLE layoffs
ALTER COLUMN Date_layoffs DATE;

-------Converting numeric columns (just incase)
ALTER TABLE layoffs
ALTER COLUMN Laid_off INT;

ALTER TABLE layoffs
ALTER COLUMN Percentage FLOAT;

ALTER TABLE layoffs
ALTER COLUMN Company_Size_before_Layoffs INT;

ALTER TABLE layoffs
ALTER COLUMN Company_Size_after_Layoffs INT;

ALTER TABLE layoffs
ALTER COLUMN Money_Raised_in__mil FLOAT;

-------Standardizing the USA country name
UPDATE layoffs
SET Country = 'United States'
WHERE Country = 'USA';

-------Standardizing the HigherEducation Industry name
UPDATE layoffs
SET Industry = 'Higher Education'
WHERE Industry = 'Higher Education Industry';

-------Handling missing data
SELECT *
FROM layoffs
WHERE Laid_Off IS NULL;

-------Removing duplicates, if present.
WITH CTE AS (
    SELECT *,
    ROW_NUMBER() OVER (
        PARTITION BY Company, Date_layoffs, Laid_Off
        ORDER BY Nr
    ) AS rn
    FROM layoffs
)
DELETE FROM CTE WHERE rn > 1;

-------Data validation check
SELECT *
FROM layoffs
WHERE Company_Size_after_layoffs > Company_Size_before_Layoffs;



--------FEATURE ENGINEERING----------
ALTER TABLE layoffs
ADD Month INT;

ALTER TABLE layoffs
ADD Stage_Group VARCHAR(50);

ALTER TABLE layoffs 
ADD Funding_Level VARCHAR(50);

UPDATE layoffs
SET 
    Month = MONTH(Date_layoffs),

    Stage_Group = 
        CASE
            WHEN Stage IN ('Seed') THEN 'Startup/Seed'
            WHEN Stage IN ('Series A', 'Series B') THEN 'Early Stage'
            WHEN Stage IN ('Series C', 'Series D', 'Series E') THEN 'Mid Stage'
            WHEN Stage IN ('Series F', 'Series G', 'Series H', 'Series I', 'Series J', 'Private Equity') THEN 'Late Stage'
            WHEN Stage IN ('Post-IPO') THEN 'Public'
            WHEN Stage IN ('Acquired', 'Subsidiary') THEN 'Acquired/Subsidiary'
            ELSE 'Unknown/Other'
        END,

    Funding_Level =
        CASE
            WHEN Money_Raised_in__mil IS NULL THEN 'Missing'
            WHEN Money_Raised_in__mil < 0 THEN 'Invalid'
            WHEN Money_Raised_in__mil < 50 THEN 'Low'
            WHEN Money_Raised_in__mil < 500 THEN 'Medium'
            ELSE 'High'
        END;



---------------------QUESTIONS---------------------
