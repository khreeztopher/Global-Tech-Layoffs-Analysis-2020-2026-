ORDER BY Total_Layoffs DESC;

/*
Q7. When did layoffs peak?
*/
SELECT Year, SUM(Laid_off) AS Total_Layoffs
FROM layoffs
GROUP BY Year
ORDER BY Year;
--How severe were layoffs over time (Layoff Rate by Year)?
SELECT 
    Year,
    SUM(Laid_Off) * 100.0 / SUM(Company_Size_before_Layoffs) AS Layoff_Rate
FROM layoffs
GROUP BY Year
ORDER BY Year;

/*
Q8.How did layoffs evolve month-by-month?
*/
SELECT YEAR(Date_layoffs) AS Year, MONTH(Date_layoffs) AS Month,
    SUM(Laid_Off) AS Total_Layoffs
FROM layoffs
GROUP BY YEAR(Date_layoffs), MONTH(Date_layoffs)
ORDER BY Year, Month;

---Highest layoff months
SELECT TOP 10 YEAR(Date_layoffs) AS Year, MONTH(Date_layoffs) AS Month,
    SUM(Laid_Off) AS Total_Layoffs
FROM layoffs
GROUP BY YEAR(Date_layoffs), MONTH(Date_layoffs)
ORDER BY Total_Layoffs DESC;

---Are layoffs concentrated in specific time periods (shock events)?
WITH Monthly AS (
    SELECT 
        DATEFROMPARTS(YEAR(Date_layoffs), MONTH(Date_layoffs), 1) AS Month_Date,
        SUM(Laid_Off) AS Total_Layoffs
    FROM layoffs
    GROUP BY YEAR(Date_layoffs), MONTH(Date_layoffs)
)

SELECT 
    Month_Date,
    Total_Layoffs,
    LAG(Total_Layoffs) OVER (ORDER BY Month_Date) AS Prev,
    Total_Layoffs - LAG(Total_Layoffs) OVER (ORDER BY Month_Date) AS Change
FROM Monthly;

/*
Q9. Are startups or late-stage companies laying off more workers?
*/
SELECT Stage_Group, SUM(Laid_Off) AS Total_Layoffs
FROM layoffs
GROUP BY Stage_Group
ORDER BY Total_Layoffs DESC;

/*
Q10. Is there a relationship between funding raised and layoffs?
*/
SELECT Funding_Level, SUM(Laid_Off) AS Total_Layoffs
FROM layoffs
GROUP BY Funding_Level;

/*
Q11. Do larger companies lay off more people?
*/
SELECT 
CASE 
    WHEN Company_Size_before_Layoffs < 100 THEN 'Small'
    WHEN Company_Size_before_Layoffs < 1000 THEN 'Medium'
    ELSE 'Large'
END AS Company_Size_Group,
SUM(Laid_Off) AS Total_Layoffs
FROM layoffs
GROUP BY 
CASE 
    WHEN Company_Size_before_Layoffs < 100 THEN 'Small'
    WHEN Company_Size_before_Layoffs < 1000 THEN 'Medium'
    ELSE 'Large'
END;

/*
Q12. What is the survival impact on companies?
*/
SELECT 
    Company,
    SUM(Company_Size_before_Layoffs) AS Total_Before,
    SUM(Company_Size_after_layoffs) AS Total_After,
    (SUM(Company_Size_after_layoffs) * 1.0 / SUM(Company_Size_before_Layoffs)) * 100 AS Survival_Rate,
    CASE
        WHEN (SUM(Company_Size_after_layoffs) * 1.0 / SUM(Company_Size_before_Layoffs)) * 100 < 50 THEN 'Critical'
        WHEN (SUM(Company_Size_after_layoffs) * 1.0 / SUM(Company_Size_before_Layoffs)) * 100 < 80 THEN 'Moderate'
        ELSE 'Stable'
    END AS Survival_Category
FROM layoffs
WHERE Company_Size_before_Layoffs > 0 
GROUP BY Company
ORDER BY Survival_Rate DESC;

/*
Q13. Do highly funded companies still lay off aggressively?
*/
SELECT 
    Company,
    Money_Raised_in__mil AS Funding_in_Milliions,
    Funding_Level,
    SUM(Company_Size_before_Layoffs) Size_before_Layofss,
    SUM(Laid_Off) AS Total_Layoffs,
    (SUM(Laid_Off) * 1.0 / SUM(Company_Size_before_Layoffs)) * 100 AS Layoff_Rate
FROM layoffs
WHERE Money_Raised_in__mil IS NOT NULL
AND Company_Size_before_Layoffs > 0
GROUP BY Company, Money_Raised_in__mil, Funding_level
ORDER BY Funding_in_Milliions DESC;
-----Funding-level aggregation
SELECT 
    Funding_Level,
    SUM(Laid_Off) AS Total_Layoffs,
    SUM(Laid_Off) * 1.0 / SUM(Company_Size_before_Layoffs) * 100 AS Layoff_Rate
FROM layoffs
WHERE Company_Size_before_Layoffs > 0
GROUP BY Funding_Level;

